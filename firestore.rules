rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation blueprint for Watchlist item
    function isValidWatchlistItem(data) {
      return data.keys().hasAll(['id', 'type', 'title', 'poster', 'backdrop', 'rating', 'year', 'genres', 'addedAt'])
        && data.keys().size() == 9
        && data.id is int
        && data.type is string && (data.type == 'movie' || data.type == 'tv')
        && data.title is string && data.title.size() <= 200
        && (data.poster == null || (data.poster is string && data.poster.size() <= 1000))
        && (data.backdrop == null || (data.backdrop is string && data.backdrop.size() <= 1000))
        && (data.rating is int || data.rating is float)
        && data.year is string && data.year.size() <= 10
        && data.genres is list
        && data.genres.size() <= 20
        && (data.genres.size() == 0 || data.genres[0] is string)
        && data.addedAt is timestamp;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /watchlist/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
